{
  "name": "rim-sage",
  "version": "0.12.1",
  "main": "src/stdio.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/stdio.ts",
    "start:http": "bun run src/http.ts",
    "clean": "bun run src/scripts/clean-db.ts",
    "index:defs": "bun run src/scripts/index-defs.ts",
    "index:csharp": "bun run src/scripts/index-csharp.ts",
    "build": "bun run clean && bun run index:defs && bun run index:csharp",
    "typecheck": "bunx tsc --noEmit --target ESNext --module Preserve --erasableSyntaxOnly $(rg --files src test -g '*.ts')"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.5.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
