{
  "name": "rim-sage",
  "version": "0.14.0",
  "main": "src/stdio.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/stdio.ts",
    "start:http": "bun run src/http.ts",
    "clean": "bun run src/scripts/clean-db.ts",
    "index:defs": "bun run src/scripts/index-defs.ts",
    "index:csharp": "bun run src/scripts/index-csharp.ts",
    "build": "bun run clean && bun run index:defs && bun run index:csharp",
    "typecheck": "bunx tsc --noEmit --target ESNext --module Preserve --erasableSyntaxOnly --skipLibCheck $(rg --files src test -g '*.ts')"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "fast-xml-parser": "^5.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
